{
  "name": "anti-bot-injector",
  "version": "1.0.0",
  "description": "Anti Bot Injector — attach antibot.dll to Rocket League",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.antibot.injector",
    "productName": "Anti Bot Injector",
    "win": {
      "target": "portable",
      "icon": "logo.png"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "auth.js",
      "pipe.js",
      "index.html",
      "logo.png",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@babel/standalone": "^7.29.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
